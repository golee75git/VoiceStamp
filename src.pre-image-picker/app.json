{
  "expo": {
    "name": "VoiceStamp",
    "slug": "VoiceStamp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.voicestamp.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "사진 촬영을 위해 카메라 접근이 필요합니다.",
          "microphonePermission": "음성 입력을 위해 마이크 접근이 필요합니다.",
          "recordAudioAndroid": true
        }
      ],
      "expo-sqlite",
      "expo-speech-recognition",
      "expo-sharing",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "제목에 위치를 넣기 위해 위치 접근이 필요합니다."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "스탬프 사진을 갤러리에 저장하기 위해 사진 접근이 필요합니다.",
          "savePhotosPermission": "스탬프 사진을 갤러리에 저장하기 위해 권한이 필요합니다.",
          "isAccessMediaLocationEnabled": false
        }
      ]
    ]
  }
}
